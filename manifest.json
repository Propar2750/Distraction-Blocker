{
  "manifest_version": 3,
  "name": "Distraction Blocker",
  "version": "1.0.0",
  "description": "Hard-blocks Instagram and gates LinkedIn and YouTube behind a code stored in the source.",
  "permissions": ["webNavigation", "tabs", "storage"],
  "host_permissions": [
    "*://*.instagram.com/*",
    "*://*.linkedin.com/*",
    "*://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["gate.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}
